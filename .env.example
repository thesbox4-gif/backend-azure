PORT=4000
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:8081

# Azure SQL (primary datastore)
AZURE_SQL_SERVER=your-server.database.windows.net
AZURE_SQL_DATABASE=your-database
AZURE_SQL_USER=adminuser
AZURE_SQL_PASSWORD=your-password
AZURE_SQL_ENCRYPT=true

# JWT auth (self-hosted; generate a strong random secret)
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_ACCESS_TTL=1h
JWT_REFRESH_TTL=30d

# Azure Blob Storage (product/category images). Until set, image upload is disabled.
AZURE_STORAGE_CONNECTION_STRING=

# Redis (for caching & rate limiting)
REDIS_URL=redis://localhost:6379
REDIS_TTL_PRODUCTS=300
REDIS_TTL_CATEGORIES=1800
REDIS_TTL_ANALYTICS=60

# Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# Anthropic AI (product title/description copywriting)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Google Gemini (nano-banana product image generation)
GOOGLE_GEMINI_API_KEY=AIza-xxxx

# Twilio WhatsApp
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
ADMIN_WHATSAPP_TO=whatsapp:+91XXXXXXXXXX

# Firebase
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"

# Multi-tenant client (used for AI quota and client-scoped settings)
CLIENT_ID=1

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
RATE_LIMIT_AUTH_MAX=10

# Shiprocket (logistics — use API user email/password from Shiprocket Settings > API)
SHIPROCKET_EMAIL=your_api_user@example.com
SHIPROCKET_PASSWORD=your_api_user_password
SHIPROCKET_PICKUP_LOCATION=Primary
SHIPROCKET_PICKUP_PINCODE=560001
SHIPROCKET_WEBHOOK_TOKEN=generate_a_random_secret_string
